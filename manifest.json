{
  "manifest_version": 3,
  "browser_specific_settings": {
    "gecko": {
      "id": "easyview@easyview.in",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  },
  "name": "EasyView — Clarity for Every Brain",
  "version": "1.1.0",
  "description": "EasyView — Clarity for Every Brain. AI-powered Chrome extension for accessible, simplified web reading.",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "alarms",
    "notifications"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "dom-utils.js",
        "content.js",
        "inject/index.js",
        "inject/payment-bridge.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "content.css",
        "inject/sensory.js",
        "fonts/kindle/Fast_OpenDyslexic/*.otf",
        "fonts/kindle/Fast_Sans/*.otf",
        "fonts/kindle/Fast_Serif/*.otf"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
